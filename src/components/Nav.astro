---
import site from "../content/settings/site.json";

interface Props {
  dark?: boolean;
  /** Float transparent over the homepage hero video */
  overlay?: boolean;
}
const { dark = false, overlay = false } = Astro.props;

const links = [
  { label: "Home", href: "/" },
  { label: "Work", href: "/portfolio" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];
const current = Astro.url.pathname;
---

<header class:list={["nav", { "nav--dark": dark, "nav--overlay": overlay }]}>
  <div class="nav__inner container">
    <a class="nav__logo" href="/" aria-label={site.brand.name}>
      <img
        src="https://cdn.prod.website-files.com/5e60706d46e6b8635dcd70e0/6765c273b63dce3e0a6cb048_PDSICON_ALPHA.png"
        alt={site.brand.name}
        width="71"
        height="100"
      />
    </a>

    <nav class="nav__links" aria-label="Primary">
      {
        links.map((l, i) => (
          <a
            class:list={[
              "nav__link",
              {
                "is-active":
                  l.href === "/"
                    ? current === "/"
                    : current === l.href || current.startsWith(l.href + "/"),
              },
            ]}
            href={l.href}
          >
            {l.label}
            <sup>º{i + 1}</sup>
          </a>
        ))
      }
    </nav>

    <a class="nav__cta" href="/contact">Get Started</a>

    <button class="nav__burger" aria-label="Open menu" data-burger>
      <span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" data-mobile hidden>
    {
      links.map((l, i) => (
        <a class="nav__mobile-link" href={l.href}>
          <span>{l.label}</span>
          <sup>º{i + 1}</sup>
        </a>
      ))
    }
    <a class="nav__mobile-link" href="/contact"><span>Get Started</span></a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }
  /* Overlay the hero video — transparent so the reel shows through */
  .nav--dark {
    background: rgba(7, 7, 12, 0.92);
    backdrop-filter: blur(10px);
    border-bottom-color: var(--line-dark);
    color: var(--text-light);
  }
  .nav--overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: transparent;
    backdrop-filter: none;
    border-bottom-color: transparent;
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 1rem;
  }
  .nav__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
  }
  .nav__logo img {
    display: block;
    height: 42px;
    width: auto;
  }
  .nav__links {
    display: flex;
    gap: clamp(1rem, 3vw, 2.75rem);
  }
  .nav__link {
    font-family: var(--font-secondary);
    font-size: var(--fs-tag);
    font-weight: 500;
    letter-spacing: var(--ls-none);
    line-height: 1.14;
    text-transform: uppercase;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  .nav__link sup {
    font-size: 0.65em;
    opacity: 0.6;
    margin-left: 1px;
  }
  .nav__link:hover,
  .nav__link.is-active {
    opacity: 1;
  }
  .nav__cta {
    font-family: var(--font-primary);
    font-size: var(--fs-body);
    font-weight: 500;
    letter-spacing: var(--ls-xlarge);
    text-transform: uppercase;
    border: 1px solid currentColor;
    border-radius: 2px;
    padding: 0.65em 1.15em;
    line-height: 1.4;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  /* Don't use background: currentColor — it tracks the new text color and
     both fill + type go dark (invisible on the homepage). */
  .nav--dark .nav__cta:hover {
    background: var(--text-light);
    color: var(--text-dark);
    border-color: var(--text-light);
  }
  .nav:not(.nav--dark) .nav__cta:hover {
    background: var(--text-dark);
    color: #fff;
    border-color: var(--text-dark);
  }
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 8px;
  }
  .nav__burger span {
    width: 22px;
    height: 2px;
    background: currentColor;
  }
  .nav__mobile {
    display: none;
    flex-direction: column;
    padding: 1rem var(--pad) 2rem;
    border-top: 1px solid var(--line);
  }
  .nav--dark .nav__mobile {
    border-top-color: var(--line-dark);
  }
  .nav__mobile-link {
    font-family: var(--font-secondary);
    text-transform: uppercase;
    letter-spacing: var(--ls-none);
    font-size: 1.1rem;
    font-weight: 500;
    padding: 0.85rem 0;
    display: flex;
    justify-content: space-between;
    border-bottom: 1px dashed var(--line);
  }
  .nav--dark .nav__mobile-link {
    border-bottom-color: var(--line-dark);
  }

  @media (max-width: 820px) {
    .nav__links,
    .nav__cta {
      display: none;
    }
    .nav__burger {
      display: flex;
    }
    .nav__mobile[data-open] {
      display: flex;
    }
  }
</style>

<script>
  const burger = document.querySelector("[data-burger]");
  const mobile = document.querySelector("[data-mobile]");
  burger?.addEventListener("click", () => {
    if (!mobile) return;
    const open = mobile.hasAttribute("data-open");
    if (open) {
      mobile.removeAttribute("data-open");
      mobile.setAttribute("hidden", "");
    } else {
      mobile.setAttribute("data-open", "");
      mobile.removeAttribute("hidden");
    }
  });
</script>
