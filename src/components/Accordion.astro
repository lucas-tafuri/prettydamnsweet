---
interface Item {
  title: string;
  body?: string;
  list?: string[];
  parenIndex?: boolean;
}
interface Props {
  items: Item[];
  idPrefix?: string;
}
const { items, idPrefix = "acc" } = Astro.props;
---

<div class="accordion" data-accordion>
  {
    items.map((item, i) => {
      const num = String(i + 1).padStart(2, "0");
      const label = item.parenIndex ? `(${num})` : `${i + 1}.`;
      return (
        <div class="accordion__item" data-item class:list={[{ "is-open": i === 0 }]}>
          <button
            class="accordion__head"
            aria-expanded={i === 0 ? "true" : "false"}
            aria-controls={`${idPrefix}-${i}`}
            data-head
          >
            <span class="accordion__num">{label}</span>
            <span class="accordion__title">{item.title}</span>
            <span class="accordion__icon" aria-hidden="true" />
          </button>
          <div class="accordion__panel" id={`${idPrefix}-${i}`} data-panel>
            <div class="accordion__panel-inner">
              {item.body && <p class="accordion__body">{item.body}</p>}
              {item.list && item.list.length > 0 && (
                <ul class="accordion__list">
                  {item.list.map((l) => (<li>{l}</li>))}
                </ul>
              )}
            </div>
          </div>
        </div>
      );
    })
  }
</div>

<style>
  .accordion__item {
    border-top: 1px dashed var(--line);
  }
  .accordion__item:last-child {
    border-bottom: 1px dashed var(--line);
  }
  .section--dark .accordion__item {
    border-color: var(--line-dark);
  }
  .accordion__head {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 1.5rem 0;
    text-align: left;
    color: inherit;
  }
  .accordion__num {
    font-family: var(--font-secondary);
    font-size: var(--fs-tag);
    font-weight: 500;
    letter-spacing: var(--ls-none);
    color: var(--muted);
    min-width: 3ch;
  }
  .accordion__title {
    font-family: var(--font-secondary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--ls-xlarge);
    font-size: var(--fs-h3);
    flex: 1;
    line-height: 1.2;
  }
  .accordion__icon {
    position: relative;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .accordion__icon::before,
  .accordion__icon::after {
    content: "";
    position: absolute;
    background: currentColor;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .accordion__icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    transform: translateY(-50%);
  }
  .accordion__icon::after {
    left: 50%;
    top: 0;
    width: 2px;
    height: 100%;
    transform: translateX(-50%);
  }
  .accordion__item.is-open .accordion__icon::after {
    transform: translateX(-50%) scaleY(0);
    opacity: 0;
  }
  .accordion__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }
  .accordion__item.is-open .accordion__panel {
    grid-template-rows: 1fr;
  }
  .accordion__panel-inner {
    overflow: hidden;
  }
  .accordion__body {
    max-width: 60ch;
    color: var(--muted-dark);
    margin: 0 0 1rem;
    padding-left: calc(3ch + 1.25rem);
    font-family: var(--font-primary);
    font-size: var(--fs-body);
    font-weight: 500;
    letter-spacing: var(--ls-xlarge);
    line-height: 1.4;
  }
  .section--dark .accordion__body {
    color: rgba(247, 247, 245, 0.72);
  }
  .accordion__list {
    list-style: none;
    margin: 0 0 1.6rem;
    padding: 0 0 0 calc(3ch + 1.25rem);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }
  .accordion__list li {
    font-family: var(--font-secondary);
    font-size: var(--fs-tag);
    font-weight: 500;
    letter-spacing: var(--ls-none);
    text-transform: uppercase;
    color: var(--muted-dark);
    position: relative;
    padding-left: 1.1rem;
  }
  .accordion__list li::before {
    content: "→";
    position: absolute;
    left: 0;
    opacity: 0.6;
  }
  .section--dark .accordion__list li {
    color: rgba(247, 247, 245, 0.72);
  }
  @media (max-width: 560px) {
    .accordion__body,
    .accordion__list {
      padding-left: 0;
    }
  }
</style>

<script>
  document.querySelectorAll("[data-accordion]").forEach((acc) => {
    const items = acc.querySelectorAll("[data-item]");
    items.forEach((item) => {
      const head = item.querySelector("[data-head]");
      head?.addEventListener("click", () => {
        const isOpen = item.classList.contains("is-open");
        items.forEach((other) => {
          other.classList.remove("is-open");
          other.querySelector("[data-head]")?.setAttribute("aria-expanded", "false");
        });
        if (!isOpen) {
          item.classList.add("is-open");
          head.setAttribute("aria-expanded", "true");
        }
      });
    });
  });
</script>
