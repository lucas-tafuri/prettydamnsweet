---
import site from "../content/settings/site.json";

const nav = [
  { label: "Home", href: "/" },
  { label: "Work", href: "/portfolio" },
  { label: "Design & Motion", href: "/portfolio/design-and-motion" },
  { label: "Branded Content", href: "/portfolio/branded-content" },
  { label: "Immersive Experiences", href: "/portfolio/immersive-experiences" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="footer section--dark">
  <div class="container">
    <p class="eyebrow eyebrow--bar">Let's work together</p>

    <div class="footer__top">
      <a class="footer__headline" href={`mailto:${site.brand.email}`}>
        <span data-split="chars">{site.brand.heroLineOne}</span>
        <span data-split="chars">{site.brand.heroLineTwo}</span>
      </a>
      <a class="btn footer__cta" href="/contact">Contact us now →</a>
    </div>

    <hr class="divider" />

    <div class="footer__grid">
      <div class="footer__col">
        <span class="footer__label">Menu</span>
        <ul>
          {nav.map((n) => (<li><a href={n.href}>{n.label}</a></li>))}
        </ul>
      </div>

      <div class="footer__col">
        <span class="footer__label">Contact</span>
        <ul>
          <li><a href={`mailto:${site.brand.email}`}>{site.brand.email}</a></li>
          <li><a href={`tel:${site.brand.phone}`}>{site.brand.phone}</a></li>
          <li>{site.brand.location}</li>
        </ul>
      </div>

      <div class="footer__col">
        <span class="footer__label">Social</span>
        <ul>
          <li><a href={site.social.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
          <li><a href={site.social.instagram} target="_blank" rel="noopener">Instagram</a></li>
          <li><a href={site.social.twitter} target="_blank" rel="noopener">Twitter</a></li>
        </ul>
      </div>
    </div>

    <hr class="divider" />

    <div class="footer__legal">
      <span>{site.brand.copyright}</span>
      <span>Immersive content studio</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .footer__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 1.5rem 0 2.5rem;
  }
  .footer__headline {
    font-family: var(--font-secondary);
    font-weight: 500;
    text-transform: uppercase;
    line-height: 0.75;
    letter-spacing: var(--ls-xlarge);
    font-size: var(--fs-display-01);
    display: flex;
    flex-direction: column;
  }
  .footer__cta {
    margin-bottom: 0.5rem;
  }
  .footer__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding-block: 2.5rem;
  }
  .footer__label {
    font-family: var(--font-secondary);
    font-size: var(--fs-tag);
    font-weight: 500;
    letter-spacing: var(--ls-none);
    line-height: 1.14;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 1.1rem;
  }
  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
    font-family: var(--font-primary);
    font-size: var(--fs-body);
    font-weight: 500;
    letter-spacing: var(--ls-xlarge);
  }
  .footer__col a:hover {
    text-decoration: underline;
  }
  .footer__legal {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    font-family: var(--font-secondary);
    font-size: var(--fs-tag);
    font-weight: 500;
    letter-spacing: var(--ls-none);
    text-transform: uppercase;
    color: var(--muted);
  }
  @media (max-width: 700px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
