---
interface Props {
  url: string;
  title?: string;
}
const { url, title = "Project video" } = Astro.props;

function toEmbed(raw: string): string | null {
  if (!raw) return null;
  const u = raw.trim();
  // Vimeo: https://vimeo.com/123456789
  const vimeo = u.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  // YouTube: watch?v=, youtu.be/, /embed/
  const yt = u.match(
    /(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([\w-]{11})/
  );
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
  return null;
}

const embed = toEmbed(url);
---

{
  embed ? (
    <div class="embed" data-animate="media">
      <iframe
        src={embed}
        title={title}
        loading="lazy"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
      />
    </div>
  ) : url ? (
    <a class="embed embed--link" href={url} target="_blank" rel="noopener">
      <span>Watch video →</span>
    </a>
  ) : null
}

<style>
  .embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 10px;
    overflow: hidden;
  }
  .embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .embed--link {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-secondary);
    text-transform: uppercase;
    letter-spacing: var(--ls-none);
    font-size: var(--fs-tag);
    font-weight: 500;
    color: #fff;
  }
</style>
